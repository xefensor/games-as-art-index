{
  "name": "games-as-art-index",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "engines": {
    "node": ">=22.13.0"
  },
  "scripts": {
    "dev": "WRANGLER_LOG_PATH=.wrangler/wrangler.log vinext dev",
    "catalogue:build": "node scripts/build-catalogue.mjs",
    "catalogue:check": "node scripts/build-catalogue.mjs --check",
    "validate:catalogue": "npm run catalogue:check && node scripts/validate-catalogue.mjs",
    "validate:thumbnails": "node scripts/validate-thumbnails.mjs",
    "thumbnails:sync": "node scripts/sync-thumbnails.mjs",
    "check:browse": "node scripts/check-browse-ui.mjs",
    "check:links": "node scripts/check-links.mjs",
    "prepare:deploy": "npm run validate:catalogue && npm run validate:thumbnails && npm run check:links && npm run check:browse && npm run build",
    "build": "npm run catalogue:build && npm run validate:catalogue && npm run validate:thumbnails && WRANGLER_LOG_PATH=.wrangler/wrangler.log vinext build && mkdir -p dist/.openai && cp .openai/hosting.json dist/.openai/hosting.json",
    "start": "WRANGLER_LOG_PATH=.wrangler/wrangler.log vinext start"
  },
  "dependencies": {
    "next": "16.2.6",
    "react": "19.2.6",
    "react-dom": "19.2.6"
  },
  "devDependencies": {
    "@cloudflare/vite-plugin": "1.37.1",
    "@vitejs/plugin-react": "6.0.2",
    "@vitejs/plugin-rsc": "0.5.26",
    "linkedom": "^0.18.13",
    "react-server-dom-webpack": "19.2.6",
    "sharp": "^0.34.5",
    "vinext": "0.0.50",
    "vite": "8.0.13",
    "wrangler": "4.92.0"
  }
}
